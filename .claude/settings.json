{
  "permissions": {
    "allow": [
      "Bash(yarn typecheck:*)",
      "Bash(yarn eslint:check:*)",
      "Bash(yarn eslint:fix:*)",
      "Bash(yarn prettier:check:*)",
      "Bash(yarn prettier:write:*)",
      "Bash(yarn db:stop)",
      "Bash(yarn db:start)",
      "Bash(yarn db:reset)",
      "Bash(yarn db:status)",
      "Bash(yarn db:diff:*)",
      "Bash(yarn db:gen-types:*)",
      "Bash(yarn db:migration:up)",
      "Bash(yarn test:*)",
      "Bash(yarn lint:sql:*)",
      "Bash(yarn fix:sql:*)",
      "Bash(git stash:*)",
      "Bash(npx eslint:*)",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__resize_page",
      "mcp__context7__query-docs",
      "mcp__claude_ai_Supabase__list_projects",
      "mcp__claude_ai_Supabase__execute_sql",
      "mcp__heroui-migration__get_component_migration_guides",
      "mcp__heroui-migration__get_migration_workflow",
      "mcp__heroui-migration__get_styling_migration_guide",
      "mcp__heroui-migration__list_component_migration_guides",
      "mcp__heroui-migration__get_hooks_migration_guide",
      "Bash(git checkout:*)",
      "Bash(yarn install:*)",
      "Bash(python3 -c ':*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/doc-reminder.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
