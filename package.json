{
  "name": "habitrack",
  "version": "0.1.0",
  "author": "Dominik Hryshaiev <domhryshaiev@gmail.com>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/domhhv/habitrack.git"
  },
  "description": "A simple calendar tracker for your habits",
  "homepage": "https://www.habitrack.io",
  "license": "MIT",
  "keywords": [
    "react",
    "typescript",
    "vite",
    "zustand",
    "eslint",
    "prettier",
    "react-aria",
    "heroui",
    "tailwind",
    "supabase",
    "rollbar"
  ],
  "scripts": {
    "prepare": "husky install",
    "prebuild": "yarn typecheck && yarn eslint:check && yarn prettier:check",
    "dev": "vite --open",
    "build": "vite build && node scripts/prerender.mjs",
    "preview": "vite preview --open",
    "typecheck": "tsc --noEmit",
    "eslint:check": "eslint .",
    "eslint:fix": "eslint --fix .",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "lint:sql": "node scripts/sqlfluff.js lint",
    "fix:sql": "node scripts/sqlfluff.js fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "yarn test --coverage",
    "test:no-cache": "yarn test --no-cache",
    "db:reset": "supabase db reset",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:restart": "yarn db:stop && yarn db:start",
    "db:diff": "supabase db diff",
    "db:diff:storage": "supabase db diff --schema storage",
    "db:migration:up": "supabase migration up",
    "db:migration:new": "supabase migration new",
    "db:gen-types": "supabase gen types --lang=typescript --schema public --schema auth --schema storage --local > supabase/database.types.ts && node scripts/patch-json-type.mjs && eslint --fix supabase/database.types.ts"
  },
  "dependencies": {
    "@heroui/react": "3.2.2",
    "@internationalized/date": "^3.12.2",
    "@phosphor-icons/react": "^2.1.10",
    "@redux-devtools/extension": "^4.0.0",
    "@rollbar/react": "^1.0.0",
    "@supabase/supabase-js": "^2.110.7",
    "@vercel/analytics": "^2.0.1",
    "border-beam": "^1.3.0",
    "browser-image-compression": "^2.0.2",
    "camelcase-keys": "^10.0.2",
    "decamelize-keys": "^2.0.1",
    "immer": "^11.1.15",
    "lodash.capitalize": "^4.2.1",
    "lodash.groupby": "^4.6.0",
    "lodash.isequal": "^4.5.0",
    "lodash.keyby": "^4.6.0",
    "pluralize": "^8.0.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-aria": "^3.50.0",
    "react-colorful": "^5.8.0",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "react-stately": "^3.48.0",
    "react-swipeable": "^7.0.2",
    "rollbar": "3.1.0",
    "type-fest": "^5.8.0",
    "typescript-eslint": "^8.65.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@relative-ci/agent": "^4.3.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/lodash.capitalize": "^4.2.9",
    "@types/lodash.groupby": "^4.6.9",
    "@types/lodash.isequal": "^4.5.8",
    "@types/lodash.keyby": "^4.6.9",
    "@types/node": "^24.13.3",
    "@types/pluralize": "^0.0.33",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-switch-case": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "rollup-plugin-webpack-stats": "^3.1.3",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "user-agent-data-types": "^0.4.3",
    "vite": "^8.1.5",
    "vite-plugin-rollbar-sourcemap": "^0.0.12",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^24.17.0"
  },
  "resolutions": {
    "@internationalized/date": "3.12.2",
    "react-aria": "3.50.0",
    "react-stately": "3.48.0",
    "map-obj": "6.0.0",
    "quick-lru": "7.3.0"
  },
  "packageManager": "yarn@4.16.0"
}
